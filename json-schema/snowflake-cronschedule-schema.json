{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CronSchedule",
  "title": "CronSchedule",
  "type": "object",
  "allOf": [
    {
      "$ref": "#/components/schemas/Schedule"
    }
  ],
  "properties": {
    "cron_expr": {
      "type": "string",
