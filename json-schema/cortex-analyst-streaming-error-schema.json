{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StreamingError",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "A description of the error"
    },
    "code": {
      "type": "string",
      "description": "The Snowflake error code categorizing the error"
    },
    "request_id": {
      "type": "string",
      "description": "Unique request ID"
    }
  }
}