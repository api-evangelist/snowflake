{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForeignKey",
  "type": "object",
  "description": "Foreign keys link data in one table to the data in another table.",
  "properties": {
    "referenced_table_name": {
      "type": "string"
    },
    "referenced_column_names": {
      "type": "array"
    }
  }
}