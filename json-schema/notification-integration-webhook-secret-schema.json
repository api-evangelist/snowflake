{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WebhookSecret",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the secret."
    },
    "database_name": {
      "type": "string",
      "description": "The database which stores the secret."
