    "name": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "login_name": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "first_name": {
      "type": "string"
    },
    "middle_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "must_change_password": {
      "type": "boolean"
    },
    "disabled": {
      "type": "boolean"
    },
    "days_to_expiry": {
      "type": "integer"
    },
    "mins_to_unlock": {
      "type": "integer"
    },
    "default_warehouse": {
      "type": "string"
