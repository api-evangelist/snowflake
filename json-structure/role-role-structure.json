{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Role",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "created_on": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "is_default": {
      "type": "boolean"
    },
    "is_current": {
      "type": "boolean"
    },
    "is_inherited": {
      "type": "boolean"
    },
    "assigned_to_users": {
      "type": "integer"
    },
    "granted_to_roles": {
      "type": "integer"
    },
    "granted_roles": {
      "type": "integer"
    }
  }
}