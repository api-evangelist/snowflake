{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Function",
  "type": "object",
  "properties": {
    "function_type": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "arguments": {
      "type": "array"
    },
    "returns": {
      "type": "string"
    },
    "max_batch_rows": {
      "type": "integer"
    },
    "created_on": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "language": {
